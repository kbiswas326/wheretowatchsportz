---
layout: base.njk
title: WhereToWatchSportz - Find Every Match, Every Stream
description: Your global sports streaming guide. Find where to watch cricket, football, Formula 1, tennis and more.
permalink: /
---

<header class="home-hero">
<div class="hero-bg"></div>

  <div class="home-hero-inner">

    <div class="hero-eyebrow">
      YOUR GLOBAL SPORTS STREAMING GUIDE
    </div>

    <h1 class="home-title">
  FIND EVERY<br>
  <span>MATCH.</span> EVERY<br>
  STREAM.
</h1>

    <p class="home-sub">
      Cricket · Football · Formula 1 · Tennis · and more
      <br>
      Indian & Global platforms, all in one place.
    </p>

    <form class="hero-search">
      <input
        type="text"
        placeholder="Search a sport, tournament or platform..."
      >
      <button>Search</button>
    </form>

    <div class="hero-badges">
      <span>Jio Cinema</span>
      <span>Hotstar</span>
      <span>Sony LIV</span>
      <span>ESPN+</span>
      <span>FLI TV</span>
      <span>DAZN</span>
      <span>Sky Sports</span>
      <span>Willow TV</span>
    </div>

  </div>

</header>

<section class="sports-section">
  <div class="section-label">BROWSE BY SPORT</div>
  <div class="section-title">Find Your Sport</div>
  
  <div class="card-grid">
    {% for sport in sports %}
      <a href="/sport/{{ sport.slug }}/" class="sport-card">
        <div class="card-sport-icon">{{ sport.emoji }}</div>
        <div class="card-body">
          <div class="card-tag">Sport</div>
          <div class="card-title">{{ sport.name }}</div>
          <div class="card-desc">{{ sport.description }}</div>
          <div class="card-platforms">
            {% for platform in sport.platforms | slice(0, 3) %}
              <span>{{ platform }}</span>
            {% endfor %}
            {% if sport.platforms.length > 3 %}
              <span>+{{ sport.platforms.length - 3 }}</span>
            {% endif %}
          </div>
        </div>
        <div class="card-arrow">→</div>
      </a>
    {% endfor %}
  </div>
</section>

<section class="sports-section">
  <div class="section-label">FREE TO WATCH</div>
  <div class="section-title">Watch Without Paying</div>

  <div class="card-grid">
    {% for platform in platforms %}
      {% if platform.isFree %}
      <a href="/platform/{{ platform.id }}/" class="sport-card">
        <div class="card-sport-icon">🆓</div>
        <div class="card-body">
          <div class="card-tag">FREE</div>
          <div class="card-title">{{ platform.name }}</div>
          <div class="card-desc">{{ platform.freeNote or platform.description }}</div>
          <div class="card-platforms">
            {% for country in platform.countries %}
              <span>{{ country | countryName }}</span>
            {% endfor %}
          </div>
        </div>
        <div class="card-arrow">→</div>
      </a>
      {% endif %}
    {% endfor %}
  </div>
</section>

<section class="sports-section">
  <div class="section-label">FEATURED TOURNAMENTS</div>
  <div class="section-title">Upcoming Events</div>
  
  <div class="card-grid">
    {% for tournament in tournaments %}
      {% if loop.index <= 4 %}
      <a href="/sport/{{ tournament.sport }}/{{ tournament.id }}/" class="sport-card">
        <div class="card-sport-icon">
          {% if tournament.sport == "cricket" %}🏏{% elif tournament.sport == "football" %}⚽{% elif tournament.sport == "f1" %}🏁{% elif tournament.sport == "tennis" %}🎾{% else %}🏆{% endif %}
        </div>
        <div class="card-body">
          <div class="card-tag">{{ tournament.sport | upper }}</div>
          <div class="card-title">{{ tournament.name }}</div>
          <div class="card-desc">{{ tournament.description }}</div>
          <div class="card-platforms">
            <span>Season {{ tournament.season }}</span>
          </div>
        </div>
        <div class="card-arrow">→</div>
      </a>
      {% endif %}
    {% endfor %}
  </div>
</section>
<section class="sports-section">

  <div class="section-label">
    LATEST NEWS
  </div>

  <div class="section-title">
    Streaming Updates
  </div>

  <div class="card-grid">

    {% for post in collections.news | reverse %}
      {% if loop.index <= 3 %}
      <a href="{{ post.url }}" class="sport-card">

        <div class="card-body">
          <div class="card-tag">NEWS</div>

          <div class="card-title">
            {{ post.data.title }}
          </div>

          <div class="card-desc">
            {{ post.data.description }}
          </div>

        </div>

        <div class="card-arrow">→</div>

      </a>
      {% endif %}
    {% endfor %}

  </div>

</section>
