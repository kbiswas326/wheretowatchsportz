---
layout: ../layouts/base.njk

pagination:
  data: platforms
  size: 1
  alias: platform

permalink: "platform/{{ platform.id }}/index.html"

eleventyComputed:
  title: "{{ platform.name }} Sports Streaming Guide"
  description: "{{ platform.description }}"
---

<header class="sport-hero">
  <div class="sport-hero-inner">

    <div class="hero-eyebrow">
      Streaming Platform
    </div>

    <h1 class="sport-hero-title">
      {{ platform.name }}
    </h1>

    <p class="sport-hero-sub">
      {{ platform.description }}
    </p>

  </div>
</header>

<main class="sport-main">

<section class="stream-section">

<div class="section-label">
Platform Information
</div>

<p>
Type: {{ platform.type }}
</p>

<p>
Price: {{ platform.price }}
</p>

<span class="stream-price {% if platform.isFree %}free-tag{% else %}paid-tag{% endif %}">
  {% if platform.isFree %}FREE{% else %}PAID{% endif %}
</span>

{% if platform.isFree and platform.freeNote %}
<p class="free-note">
  {{ platform.freeNote }}
</p>
{% endif %}

<p>
Available in:
{% for c in platform.countries %}{{ c | countryName }}{% if not loop.last %}, {% endif %}{% endfor %}
</p>

</section>

<section class="stream-section">

<h2>Sports Covered</h2>

<ul>
{% for sport in platform.sports %}
<li>{{ sport }}</li>
{% endfor %}
</ul>
</section>

<section class="stream-section">

<div class="section-label">
Popular Tournaments
</div>

<div class="card-grid">

{% for tournament in tournaments %}

{% for country, info in tournament.broadcasts %}

{% if info.streaming == platform.name %}

<a href="/sport/{{ tournament.sport }}/{{ tournament.id }}/" class="sport-card">
  <div class="card-sport-icon">
    {% if tournament.sport == "cricket" %}🏏{% elif tournament.sport == "football" %}⚽{% elif tournament.sport == "f1" %}🏁{% elif tournament.sport == "tennis" %}🎾{% elif tournament.sport == "basketball" %}🏀{% elif tournament.sport == "golf" %}⛳{% else %}🏆{% endif %}
  </div>
  <div class="card-body">
    <div class="card-tag">{{ tournament.sport | upper }}</div>
    <div class="card-title">{{ tournament.name }}</div>
    <div class="card-desc">{{ tournament.description }}</div>
  </div>
  <div class="card-arrow">→</div>
</a>

{% endif %}

{% endfor %}

{% endfor %}

</div>

</section>

</main>
