---
layout: ../layouts/base.njk

pagination:
  data: platforms
  size: 1
  alias: platform

permalink: "platform/{{ platform.id }}/index.html"

eleventyComputed:
  title: "{{ platform.name }} — Sports Streaming Guide"
  description: "Find out which sports you can watch on {{ platform.name }}. Pricing, regions, and full sports coverage breakdown."
---

<header class="sport-hero">
  <div class="sport-hero-inner">
    <div class="hero-eyebrow">Streaming Platform</div>
    <h1 class="sport-hero-title">{{ platform.name }}</h1>
    <p class="sport-hero-sub">{{ platform.region }} · {{ platform.price }}</p>
  </div>
</header>

<main class="sport-main">

  <section class="stream-section">
    <div class="section-label">Overview</div>
    <p>{{ platform.name }} is a sports streaming platform available in {{ platform.region }}. {% if platform.free %}A free tier is available.{% endif %}</p>
  </section>

  <section class="stream-section">
    <div class="section-label">Sports Covered</div>
    <ul>
      {% for sport in platform.sports %}
      <li>{{ sport }}</li>
      {% endfor %}
    </ul>
  </section>

  {% if platform.notes %}
  <section class="stream-section">
    <div class="section-label">Notes</div>
    <p>{{ platform.notes }}</p>
  </section>
  {% endif %}

  <section class="stream-section">
    <div class="section-label">Visit Platform</div>
    <a class="stream-cta" href="{{ platform.url }}" target="_blank" rel="noopener nofollow">
      Go to {{ platform.name }} →
    </a>
  </section>

</main>
